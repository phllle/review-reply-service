PORT=3000
LOG_LEVEL=info

# Required in production: signs browser session cookie after Google OAuth (use a long random string)
REPLYR_SESSION_SECRET=

# Admin UI (/admin?secret=...) and X-Admin-Secret on /businesses, /auto/process (env fallback), /admin.js
ADMIN_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

ALLOWED_ORIGINS=*

# Optional: Google account IDs (comma/space-separated) that get base Replyr without paying (trial/subscription gates bypassed for auto-reply). Example: REPLYR_GRATIS_ACCOUNT_IDS=113560731433398021904
REPLYR_GRATIS_ACCOUNT_IDS=

# Stripe – base plan (Replyr)
STRIPE_SECRET_KEY=
# Base Replyr plan ($19 etc.) — Price ID price_... (optional alias: STRIPE_BASE_PRICE_ID)
STRIPE_PRICE_ID=
# STRIPE_BASE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BASE_URL=http://localhost:3000
SUBSCRIBE_PRICE=$19 / month
STRIPE_CUSTOMER_PORTAL_URL=

# Stripe – Replyr Pro (Checkout + webhook sets is_pro and pro_tier)
# Legacy single Pro price (maps to pro_tier starter if no tier IDs set):
STRIPE_PRO_PRICE_ID=
# Tiered Pro (recommended): Starter 500 SMS, Growth 2,500 SMS, Scale 10,000 SMS
STRIPE_PRO_STARTER_PRICE_ID=
STRIPE_PRO_GROWTH_PRICE_ID=
STRIPE_PRO_SCALE_PRICE_ID=
# Labels on /subscribe (optional; code has sensible defaults)
SUBSCRIBE_PRO_STARTER_PRICE=$39 / month
SUBSCRIBE_PRO_GROWTH_PRICE=$69 / month
SUBSCRIBE_PRO_SCALE_PRICE=$149 / month
# Optional: Payment Link instead of Checkout for Pro (no automatic is_pro)
SUBSCRIBE_PRO_URL=
SUBSCRIBE_PRO_PRICE=$39 / month

# Pro campaigns (Resend; same key as alerts)
RESEND_API_KEY=
ALERT_FROM_EMAIL=Replyr <onboarding@resend.dev>
UNSUBSCRIBE_SECRET=
CAMPAIGN_FOOTER_ADDRESS=

# Pro campaigns – SMS to customers (Twilio). Must be true to send campaign SMS; Twilio vars must also be set.
CAMPAIGN_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Contact us page and failure alerts (email and optional phone)
ALERT_EMAIL=
ALERT_PHONE=
TEST_ALERT_SECRET=
